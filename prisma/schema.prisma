generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
  GUEST
}

model User {
  id      String   @id @default(cuid())
  name    String
  email   String   @unique
  nfc_uid String   @unique
  role    UserRole @default(MEMBER)
}

model AccessLog {
  id        String   @id @default(cuid())
  nfc_uid   String
  timestamp DateTime @default(now())
  granted   Boolean

  @@index([nfc_uid])
  @@index([timestamp])
}
