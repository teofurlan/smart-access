generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  MEMBER
  GUEST
}

enum AccessDenialReason {
  UNKNOWN_CARD
  NO_ACTIVE_RESERVATION
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  nfc_uid     String   @unique
  role        UserRole @default(MEMBER)
  spotify_uri String?
}

model AccessLog {
  id             String               @id @default(cuid())
  nfc_uid        String
  timestamp      DateTime             @default(now())
  granted        Boolean
  message        String?
  denial_reason  AccessDenialReason?
  user_name      String?

  @@index([nfc_uid])
  @@index([timestamp])
}
